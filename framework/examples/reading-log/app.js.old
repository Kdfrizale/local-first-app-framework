/**
 * Reading Log App
 * Track books read by family members
 * 
 * Refactored to use the App base class
 */

class ReadingLogApp extends App {
  constructor() {
    super({
      appName: 'reading-log',
      dataPath: 'apps/reading-log/data.json',
      initialState: {
        books: [],
        readers: [],
        searchQuery: '',
        readerFilter: '',
        sortBy: 'date-desc'
      }
    });
  }

  async onInit() {
    // Subscribe to state changes for re-rendering
    this.state.subscribe('books', () => this.renderBooks());
    this.state.subscribe('searchQuery', () => this.renderBooks());
    this.state.subscribe('readerFilter', () => this.renderBooks());
    this.state.subscribe('sortBy', () => this.renderBooks());
    
    this.setupEventHandlers();
  }

  onDataLoaded(data, source) {
    this.state.set({
      books: data.books || [],
      readers: data.readers || []
    });
    this.updateReadersFilter();
    this.renderBooks();
    this.renderStats();
  }

  getData() {
    return {
      books: this.state.get('books'),
      readers: this.state.get('readers')
    };
  }

  setupEventHandlers() {
    document.getElementById('sync-btn')?.addEventListener('click', () => this.sync());
    document.getElementById('settings-btn')?.addEventListener('click', () => this.showSettings());
    document.getElementById('add-book-btn')?.addEventListener('click', () => this.showAddBook());
    
    const searchInput = document.getElementById('search-input');
    searchInput?.addEventListener('input', (e) => this.state.set('searchQuery', e.target.value));
    
    const sortSelect = document.getElementById('sort-select');
    sortSelect?.addEventListener('change', (e) => this.state.set('sortBy', e.target.value));
    
    const readerSelect = document.getElementById('reader-filter');
    readerSelect?.addEventListener('change', (e) => this.state.set('readerFilter', e.target.value));
  }

  // --- Rendering ---

  renderBooks() {
    const container = document.getElementById('books-container');
    if (!container) return;
    
    if (!this.state.get('isSetup')) {
      this.showSetupScreen();
      return;
    }
    
    let books = this.getFilteredBooks();
    
    if (books.length === 0) {
      container.innerHTML = this.renderEmptyState();
      return;
    }
    
    container.innerHTML = books.map(book => this.renderBookCard(book)).join('');
  }

  renderBookCard(book) {
    const ratingStars = '★'.repeat(book.rating || 0) + '☆'.repeat(5 - (book.rating || 0));
    
    return `
      <div class="book-card bg-white rounded-lg shadow-md p-4 mb-4 border-l-4 border-violet-500">
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <h3 class="font-bold text-lg text-gray-900">${this.escapeHtml(book.title)}</h3>
            <p class="text-gray-600">${this.escapeHtml(book.author || 'Unknown Author')}</p>
            <div class="flex items-center gap-4 mt-2 text-sm text-gray-500">
              <span class="text-yellow-500">${ratingStars}</span>
              <span>📖 ${this.escapeHtml(book.reader || 'Unknown')}</span>
              <span>📅 ${book.dateRead ? new Date(book.dateRead).toLocaleDateString() : 'No date'}</span>
            </div>
            ${book.notes ? `<p class="mt-2 text-sm text-gray-600 italic">"${this.escapeHtml(book.notes)}"</p>` : ''}
          </div>
          <div class="flex gap-2">
            <button onclick="app.showEditBook('${book.id}')" class="text-gray-400 hover:text-violet-600">✏️</button>
            <button onclick="app.deleteBook('${book.id}')" class="text-gray-400 hover:text-red-600">🗑️</button>
          </div>
        </div>
      </div>
    `;
  }

  renderEmptyState() {
    const hasFilters = this.state.get('searchQuery') || this.state.get('readerFilter');
    
    return `
      <div class="text-center py-12">
        <span class="text-6xl mb-4 block">📚</span>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          ${hasFilters ? 'No matching books' : 'No books yet'}
        </h2>
        <p class="text-gray-600 mb-8">
          ${hasFilters ? 'Try adjusting your filters' : 'Start tracking your reading journey!'}
        </p>
        ${!hasFilters ? `
          <button onclick="app.showAddBook()" class="px-6 py-3 bg-violet-600 text-white rounded-md hover:bg-violet-700">
            📖 Add Your First Book
          </button>
        ` : ''}
      </div>
    `;
  }

  renderStats() {
    const container = document.getElementById('stats-container');
    if (!container) return;
    
    const books = this.state.get('books') || [];
    const readers = this.state.get('readers') || [];
    const thisYear = books.filter(b => {
      const date = new Date(b.dateRead);
      return date.getFullYear() === new Date().getFullYear();
    });
    
    container.innerHTML = `
      <div class="grid grid-cols-3 gap-4 text-center">
        <div class="bg-white rounded-lg p-4 shadow">
          <div class="text-3xl font-bold text-violet-600">${books.length}</div>
          <div class="text-sm text-gray-500">Total Books</div>
        </div>
        <div class="bg-white rounded-lg p-4 shadow">
          <div class="text-3xl font-bold text-violet-600">${thisYear.length}</div>
          <div class="text-sm text-gray-500">This Year</div>
        </div>
        <div class="bg-white rounded-lg p-4 shadow">
          <div class="text-3xl font-bold text-violet-600">${readers.length}</div>
          <div class="text-sm text-gray-500">Readers</div>
        </div>
      </div>
    `;
  }

  // --- Filtering ---

  getFilteredBooks() {
    let books = [...(this.state.get('books') || [])];
    const searchQuery = this.state.get('searchQuery')?.toLowerCase() || '';
    const readerFilter = this.state.get('readerFilter');
    const sortBy = this.state.get('sortBy');
    
    // Filter by search
    if (searchQuery) {
      books = books.filter(b =>
        b.title?.toLowerCase().includes(searchQuery) ||
        b.author?.toLowerCase().includes(searchQuery) ||
        b.notes?.toLowerCase().includes(searchQuery)
      );
    }
    
    // Filter by reader
    if (readerFilter) {
      books = books.filter(b => b.reader === readerFilter);
    }
    
    // Sort
    books.sort((a, b) => {
      switch (sortBy) {
        case 'date-asc':
          return new Date(a.dateRead || 0) - new Date(b.dateRead || 0);
        case 'title':
          return (a.title || '').localeCompare(b.title || '');
        case 'rating':
          return (b.rating || 0) - (a.rating || 0);
        case 'date-desc':
        default:
          return new Date(b.dateRead || 0) - new Date(a.dateRead || 0);
      }
    });
    
    return books;
  }

  updateReadersFilter() {
    const select = document.getElementById('reader-filter');
    if (!select) return;
    
    const readers = this.state.get('readers') || [];
    const currentFilter = this.state.get('readerFilter');
    
    select.innerHTML = `
      <option value="">All Readers</option>
      ${readers.map(r => `<option value="${this.escapeHtml(r)}" ${r === currentFilter ? 'selected' : ''}>${this.escapeHtml(r)}</option>`).join('')}
    `;
  }

  // --- CRUD Operations ---

  showAddBook() {
    modal.show({
      title: '📖 Add New Book',
      content: this.getBookFormHtml(),
      buttons: [
        { text: 'Cancel', onClick: () => modal.close() },
        {
          text: 'Add Book',
          primary: true,
          onClick: () => {
            const data = FormHelper.getData('#book-form');
            if (!data.title?.trim()) {
              toast.error('Title is required');
              return;
            }
            this.addBook(data);
            modal.close();
          }
        }
      ]
    });
  }

  showEditBook(id) {
    const book = this.state.get('books').find(b => b.id === id);
    if (!book) return;
    
    modal.show({
      title: '✏️ Edit Book',
      content: this.getBookFormHtml(book),
      buttons: [
        { text: 'Cancel', onClick: () => modal.close() },
        {
          text: 'Save Changes',
          primary: true,
          onClick: () => {
            const data = FormHelper.getData('#book-form');
            if (!data.title?.trim()) {
              toast.error('Title is required');
              return;
            }
            this.updateBook(id, data);
            modal.close();
          }
        }
      ]
    });
  }

  getBookFormHtml(book = {}) {
    const readers = this.state.get('readers') || [];
    
    return `
      <form id="book-form" class="space-y-4">
        <div>
          <label class="form-label">Title *</label>
          <input type="text" name="title" required class="form-input" value="${this.escapeHtml(book.title || '')}">
        </div>
        <div>
          <label class="form-label">Author</label>
          <input type="text" name="author" class="form-input" value="${this.escapeHtml(book.author || '')}">
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="form-label">Reader</label>
            <select name="reader" class="form-input">
              <option value="">Select reader</option>
              ${readers.map(r => `<option value="${this.escapeHtml(r)}" ${r === book.reader ? 'selected' : ''}>${this.escapeHtml(r)}</option>`).join('')}
            </select>
            <input type="text" name="newReader" placeholder="Or add new reader" class="form-input mt-2">
          </div>
          <div>
            <label class="form-label">Date Read</label>
            <input type="date" name="dateRead" class="form-input" value="${book.dateRead || ''}">
          </div>
        </div>
        <div>
          <label class="form-label">Rating</label>
          <select name="rating" class="form-input">
            ${[5,4,3,2,1].map(n => `<option value="${n}" ${book.rating === n ? 'selected' : ''}>${'★'.repeat(n)}${'☆'.repeat(5-n)}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="form-label">Notes</label>
          <textarea name="notes" class="form-input" rows="3">${this.escapeHtml(book.notes || '')}</textarea>
        </div>
      </form>
    `;
  }

  addBook(data) {
    const books = this.state.get('books') || [];
    const readers = this.state.get('readers') || [];
    
    // Handle new reader
    let reader = data.reader;
    if (data.newReader?.trim()) {
      reader = data.newReader.trim();
      if (!readers.includes(reader)) {
        this.state.set('readers', [...readers, reader]);
      }
    }
    
    const newBook = {
      id: this.generateId(),
      title: data.title.trim(),
      author: data.author?.trim() || '',
      reader: reader || '',
      dateRead: data.dateRead || new Date().toISOString().split('T')[0],
      rating: parseInt(data.rating) || 3,
      notes: data.notes?.trim() || '',
      createdAt: new Date().toISOString(),
      updatedAt: new Date().toISOString()
    };
    
    this.state.set('books', [...books, newBook]);
    this.updateReadersFilter();
    this.saveData();
    toast.success('Book added!');
  }

  updateBook(id, data) {
    const books = this.state.get('books').map(book => {
      if (book.id === id) {
        // Handle new reader
        let reader = data.reader;
        if (data.newReader?.trim()) {
          reader = data.newReader.trim();
          const readers = this.state.get('readers') || [];
          if (!readers.includes(reader)) {
            this.state.set('readers', [...readers, reader]);
          }
        }
        
        return {
          ...book,
          title: data.title.trim(),
          author: data.author?.trim() || '',
          reader: reader || book.reader,
          dateRead: data.dateRead || book.dateRead,
          rating: parseInt(data.rating) || book.rating,
          notes: data.notes?.trim() || '',
          updatedAt: new Date().toISOString()
        };
      }
      return book;
    });
    
    this.state.set('books', books);
    this.updateReadersFilter();
    this.saveData();
    toast.success('Book updated!');
  }

  async deleteBook(id) {
    const confirmed = await modal.confirm('Delete this book from your reading log?', 'Delete Book');
    if (!confirmed) return;
    
    const books = this.state.get('books').filter(b => b.id !== id);
    this.state.set('books', books);
    this.saveData();
    toast.success('Book deleted!');
  }

  // --- Utilities ---

  generateId() {
    return Date.now().toString(36) + Math.random().toString(36).substr(2);
  }

  escapeHtml(str) {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
}

// Initialize app
let app;
document.addEventListener('DOMContentLoaded', async () => {
  app = new ReadingLogApp();
  await app.init();
});
